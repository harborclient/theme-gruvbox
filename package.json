{
  "name": "@harborclient/plugin-gruvbox",
  "type": "module",
  "scripts": {
    "release": "bash scripts/publish.sh",
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "screenshot": "bash scripts/render-screenshot.sh",
    "pack": "pnpm build && zip -r ../gruvbox.hcp manifest.json README.md assets dist",
    "plugin:sign": "node --experimental-strip-types scripts/plugin-sign.ts",
    "plugin:verify": "node --experimental-strip-types scripts/plugin-verify.ts"
  },
  "dependencies": {
    "@harborclient/sdk": "^1.0.33"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "typescript": "^5.0.0"
  }
}
