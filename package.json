{
  "name": "@harborclient/plugin-gruvbox",
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "build": "esbuild src/renderer.tsx --bundle --outfile=dist/renderer.js --format=esm --external:react --external:react-dom",
    "dev": "esbuild src/renderer.tsx --bundle --outfile=dist/renderer.js --format=esm --external:react --external:react-dom --watch",
    "screenshot": "bash scripts/render-screenshot.sh",
    "pack": "pnpm build && zip -r ../gruvbox.hcp manifest.json README.md assets dist",
    "plugin:sign": "node --experimental-strip-types scripts/plugin-sign.ts",
    "plugin:verify": "node --experimental-strip-types scripts/plugin-verify.ts"
  },
  "dependencies": {
    "@harborclient/sdk": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "esbuild": "^0.25.0",
    "react": "^19.2.7",
    "typescript": "^5.0.0"
  }
}
